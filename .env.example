# Chave da API da Anthropic usada pelo assistente LLM (Etapa 5).
# Nunca preencher com valor real neste arquivo de exemplo.
ANTHROPIC_API_KEY=

# Token da API do Kaggle para baixar a base bank-marketing (Etapa 1).
# Gere em https://www.kaggle.com/settings/api -> "API Tokens" -> nomeie o token -> Generate
KAGGLE_API_TOKEN=

# URI de tracking do MLflow (Etapa 7). Padrao: arquivo local.
MLFLOW_TRACKING_URI=file:./mlruns
